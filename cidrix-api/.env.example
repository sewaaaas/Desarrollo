# =============================================================================
# CIDRIX API — Environment Variables
# Copia este archivo a .env y completa los valores para tu entorno.
# NUNCA hagas commit del archivo .env real.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Database (BE-02 — Docker Compose)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://cidrix_user:cidrix_pass@localhost:5432/cidrix_db

# -----------------------------------------------------------------------------
# Authentication (BE-06 — JWT)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change_this_to_a_secure_random_string_minimum_32_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_a_different_secure_random_string_minimum_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Lista de orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
BCRYPT_SALT_ROUNDS=10

# -----------------------------------------------------------------------------
# File Storage (Sprint 3)
# -----------------------------------------------------------------------------
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads